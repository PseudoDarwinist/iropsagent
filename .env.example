# Flight Agent Environment Variables

# Database Configuration
DATABASE_URL=sqlite:///./travel_disruption.db

# Flight APIs
FLIGHTAWARE_API_KEY=your_flightaware_api_key_here
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

# Email Configuration
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# To set up Twilio SMS notifications:
# 1. Sign up for a Twilio account at https://twilio.com
# 2. Get your Account SID and Auth Token from the Twilio Console
# 3. Purchase a phone number from Twilio for sending SMS
# 4. Add the credentials above to your .env file